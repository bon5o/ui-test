  },
  "chapters": [
    {
      "id": "overview",
      "title": "概要",
      "sections": [
        {
      "id": "optical_formula",
      "title": "光学構成図",
      "items": [
        {
          "type": "image",
          "src": "/images/lens-types/double-gauss/double-gauss.jpg",
          "caption": "ダブルガウス型の基本構成図"
        }
